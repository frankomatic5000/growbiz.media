# GrowBiz Media — Environment Variables
# Copy to .env.local and fill in your values

# ── Sanity CMS ────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
SANITY_API_TOKEN=                    # Server-only — never expose in client

# ── Google Analytics ──────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=

# ── Hub Contact ───────────────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=         # Format: 15551234567 (no + or spaces)
NEXT_PUBLIC_FORMSPREE_ID=

# ── ClipIQ — Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── ClipIQ — Auth.js (NextAuth v5) ───────────────────────────────────
NEXTAUTH_SECRET=                     # openssl rand -base64 32
NEXTAUTH_URL=https://growbiz.media   # http://localhost:3000 for dev

# Google OAuth — https://console.cloud.google.com → APIs & Services → OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── ClipIQ — Email (Magic Link via Brevo SMTP) ────────────────────────
EMAIL_SERVER_HOST=smtp-relay.brevo.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=                   # Brevo SMTP login
EMAIL_SERVER_PASSWORD=               # Brevo SMTP key
EMAIL_FROM=noreply@growbiz.media

# ── ClipIQ — Vercel KV (Redis) ────────────────────────────────────────
# Create at: Vercel Dashboard → Storage → Create → KV
# These are auto-added when you link the KV store to the project
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ── ClipIQ — Microsoft Teams Notifications ────────────────────────────
# Setup: Teams channel → ··· → Connectors → Incoming Webhook → Configure → copy URL
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/...

# ── ClipIQ — Vercel Cron Security ─────────────────────────────────────
CRON_SECRET=                         # openssl rand -base64 32
