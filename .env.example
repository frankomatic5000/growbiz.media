# GrowBiz Media — Environment Variables
# Copy to .env.local and fill in your values

# ── Sanity CMS ────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
SANITY_API_TOKEN=                    # Server-only — never expose in client

# ── Google Analytics ──────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=

# ── Hub Contact ───────────────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=         # Format: 15551234567 (no + or spaces)
NEXT_PUBLIC_FORMSPREE_ID=

# ── ClipIQ — Auth.js (NextAuth v5) ───────────────────────────────────
# IMPORTANT: NextAuth v5 uses AUTH_SECRET (not NEXTAUTH_SECRET)
AUTH_SECRET=                         # openssl rand -base64 32
NEXTAUTH_URL=https://growbiz.media   # http://localhost:3000 for dev

# Google OAuth — https://console.cloud.google.com → APIs & Services → OAuth
# Must include scope: https://www.googleapis.com/auth/drive.readonly
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Google Picker API key — enables folder browser UI (safe to expose publicly)
# Enable "Google Picker API" in Cloud Console → APIs & Services → Library
NEXT_PUBLIC_GOOGLE_API_KEY=

# ── ClipIQ — Email (Magic Link via Brevo SMTP) ────────────────────────
EMAIL_SERVER_HOST=smtp-relay.brevo.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=                   # Brevo SMTP login
EMAIL_SERVER_PASSWORD=               # Brevo SMTP key
EMAIL_FROM=noreply@growbiz.media

# ── ClipIQ — Vercel KV (Upstash Redis) ───────────────────────────────
# Create at: Vercel Dashboard → Storage → Create → KV (Upstash)
# These are auto-added when you link the KV store to the project
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── ClipIQ — AI APIs ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...        # https://console.anthropic.com
OPENAI_API_KEY=sk-...               # https://platform.openai.com (for Whisper transcription)

# ── ClipIQ — Social Platform OAuth ───────────────────────────────────
# Meta (Instagram + Facebook)
# https://developers.facebook.com → My Apps → Create → Consumer
META_APP_ID=
META_APP_SECRET=

# X / Twitter
# https://developer.twitter.com → Projects & Apps → Create App → OAuth 2.0
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# TikTok
# https://developers.tiktok.com → Manage apps → Create app
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── ClipIQ — Microsoft Teams Notifications ────────────────────────────
# Teams channel → ··· → Connectors → Incoming Webhook → Configure → copy URL
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/...

# ── ClipIQ — Vercel Cron Security ─────────────────────────────────────
CRON_SECRET=                         # openssl rand -base64 32
